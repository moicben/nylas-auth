{
  "functions": {
    "api/gateway.js": {
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/brief-strategie-2026.docx",
      "destination": "/document-access?lang=fr",
      "permanent": false
    },
    {
      "source": "/recap-echange-lastproV1.docx",
      "destination": "/document-access?lang=fr",
      "permanent": false
    },
    {
      "source": "/strategic-overview-2026.docx",
      "destination": "/document-access?lang=en",
      "permanent": false
    },
    {
      "source": "/strategic-ovierview-2026.docx",
      "destination": "/document-access?lang=en",
      "permanent": false
    },
    {
      "source": "/qc-brief-mission-2026.docx",
      "destination": "/document-access?lang=qc",
      "permanent": false
    },
    {
      "source": "/gestion2026-strategie.docx",
      "destination": "/document-access?lang=fr",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "https://workspace.google.com",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/gateway?__route=$1"
    },
    {
      "source": "/auth/callback",
      "destination": "/auth/callback/index.html"
    },
    {
      "source": "/auth-verification",
      "destination": "/auth-verification/index.html"
    },
    {
      "source": "/inbox",
      "destination": "/inbox/index.html"
    }
  ]
}
